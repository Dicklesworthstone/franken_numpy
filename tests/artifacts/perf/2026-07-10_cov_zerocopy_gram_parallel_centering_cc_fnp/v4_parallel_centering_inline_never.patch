+// Center each variable row by its own mean: `src(r)` hands back row r's raw source
+// slice. The per-row mean stays a sequential in-order sum and the subtraction stays
+// elementwise, so each row is bit-identical to the historical serial loop; rows are
+// independent, so fan out across them once the matrix is big enough to amortize the
+// rayon dispatch (the serial pass was ~0.5-1 ms of the cov 2000x500 hotspot).
+//
+// inline(never) is LOAD-BEARING: letting this generic inline into the cov gram
+// callers perturbed LLVM's whole-caller register allocation under
+// lto=true/codegen-units=1 and spilled the MR=4 Gram tile's ymm accumulators --
+// measured 5x slower cov at n_vars >= ~1600 (49.5 ms vs 13 ms at 1900x500) with
+// zero source change to the kernel itself. See docs/NEGATIVE_EVIDENCE.md 2026-07-09.
+#[inline(never)]
+fn center_rows<'a>(centered: &mut [f64], n_obs: usize, src: impl Fn(usize) -> &'a [f64] + Sync) {
+    use rayon::prelude::*;
+    let center_one = |(r, dst): (usize, &mut [f64])| {
+        let s = src(r);
+        let mean = s.iter().sum::<f64>() / n_obs as f64;
+        for (o, &v) in dst.iter_mut().zip(s) {
+            *o = v - mean;
+        }
+    };
+    if centered.len() >= (1 << 20) && rayon::current_num_threads() >= 2 {
+        centered.par_chunks_mut(n_obs).enumerate().for_each(center_one);
+    } else {
+        centered.chunks_mut(n_obs).enumerate().for_each(center_one);
+    }
+}
